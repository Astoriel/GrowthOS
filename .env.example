# GrowthOS Configuration
# Point to a directory with your marketing CSV files
GROWTH_DATA_DIR=./data/sample

# Optional: connect to a remote PostgreSQL database
POSTGRES_URL=

# Optional: sync Stripe billing data
STRIPE_API_KEY=
STRIPE_BASE_URL=https://api.stripe.com/v1

# Optional: sync Meta Ads data
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
META_API_VERSION=v21.0
META_BASE_URL=https://graph.facebook.com

# Optional: sync Google Ads data
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_API_VERSION=v19
GOOGLE_ADS_BASE_URL=https://googleads.googleapis.com
GOOGLE_ADS_OAUTH_TOKEN_URL=https://oauth2.googleapis.com/token

# Optional: explicit attribution alias mappings (CSV)
ATTRIBUTION_MAPPING_FILE=
ATTRIBUTION_MAPPING_HISTORY_PATH=
SEMANTIC_PROFILE_PATH=

# Query limits
MAX_QUERY_ROWS=10000
QUERY_TIMEOUT_SECONDS=30
